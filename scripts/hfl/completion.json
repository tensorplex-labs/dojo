      "completion": "{\"files\": [{\"filename\": \"index.html\", \"content\": \"<!DOCTYPE html>\\n<html lang=\\\"en\\\"><head><meta charset=\\\"utf-8\\\"/><meta content=\\\"width=device-width,initial-scale=1.0\\\" name=\\\"viewport\\\"/><title>Park Perfection</title><style>body,html{margin:0;padding:0;height:100%;overflow:hidden;font-family:Arial,sans-serif}#gameContainer{position:relative;width:100vmin;height:100vmin;margin:auto}#gameCanvas{position:absolute;top:0;left:0;width:100%;height:100%;background-color:#90EE90}#hud{position:absolute;top:10px;left:10px;right:10px;display:flex;justify-content:space-between;color:#2F4F4F;font-size:18px;background:rgba(255,255,255,0.8);padding:10px;border-radius:5px}#selectedItem{position:absolute;top:60px;left:10px;background:rgba(255,255,255,0.8);padding:10px;border-radius:5px}#gameOver{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(0,0,0,0.8);color:white;padding:20px;border-radius:10px;text-align:center;display:none}#controls{position:absolute;bottom:10px;left:50%;transform:translateX(-50%);background:rgba(255,255,255,0.8);padding:10px;border-radius:5px;font-size:14px}</style></head><body><div id=\\\"gameContainer\\\"><canvas id=\\\"gameCanvas\\\"></canvas><div id=\\\"hud\\\"><span id=\\\"budget\\\">Budget: 1000</span><span id=\\\"satisfaction\\\">Satisfaction: 0%</span><span id=\\\"bestScore\\\">Best Score: 0</span></div><div id=\\\"selectedItem\\\">Selected: None</div><div id=\\\"controls\\\">1-4: Select Amenity | Click: Place | Right Click: Remove Problem</div><div id=\\\"gameOver\\\"><h2>Game Over!</h2><p>Final Score: <span id=\\\"finalScore\\\">0</span></p><button onclick=\\\"location.reload()\\\">Play Again</button></div></div><script src=\\\"index.js\\\"></script><script>const canvas=document.getElementById('gameCanvas');const ctx=canvas.getContext('2d');const GRID_SIZE=20;const CELL_SIZE=canvas.width/GRID_SIZE;let budget=1000;let satisfaction=50;let bestScore=0;let selectedAmenity=null;let gameOver=false;const amenities={1:{name:'Bench',cost:100,color:'#8B4513',size:1},2:{name:'Tree',cost:150,color:'#228B22',size:1},3:{name:'Playground',cost:300,color:'#FFD700',size:2},4:{name:'Fountain',cost:400,color:'#4169E1',size:2}};class Grid{constructor(){this.cells=Array(GRID_SIZE).fill().map(()=>Array(GRID_SIZE).fill(null));this.problemSpots=new Set();}}class NPC{constructor(){this.x=Math.random()*canvas.width;this.y=Math.random()*canvas.height;this.targetX=this.x;this.targetY=this.y;this.speed=2;this.interactionTimer=0;}update(){const dx=this.targetX-this.x;const dy=this.targetY-this.y;const dist=Math.sqrt(dx*dx+dy*dy);if(dist<this.speed){this.pickNewTarget();}else{this.x+=dx/dist*this.speed;this.y+=dy/dist*this.speed;}this.interactionTimer--;}pickNewTarget(){const nearbyAmenity=findNearestAmenity(this.x,this.y);if(nearbyAmenity&&Math.random()<0.7){this.targetX=nearbyAmenity.x;this.targetY=nearbyAmenity.y;}else{this.targetX=Math.random()*canvas.width;this.targetY=Math.random()*canvas.height;}}draw(){ctx.fillStyle='#4B0082';ctx.beginPath();ctx.arc(this.x,this.y,5,0,Math.PI*2);ctx.fill();}}const grid=new Grid();const npcs=Array(10).fill().map(()=>new NPC());let placedAmenities=[];function findNearestAmenity(x,y){let nearest=null;let minDist=Infinity;for(const amenity of placedAmenities){const dx=amenity.x-x;const dy=amenity.y-y;const dist=dx*dx+dy*dy;if(dist<minDist){minDist=dist;nearest=amenity;}}return nearest;}function createSparkleEffect(x,y){const particles=[];for(let i=0;i<10;i++){particles.push({x:x,y:y,vx:(Math.random()-0.5)*5,vy:(Math.random()-0.5)*5,life:20});}return particles;}function drawSparkles(particles){particles.forEach((p,i)=>{p.x+=p.vx;p.y+=p.vy;p.life--;ctx.fillStyle=`rgba(255,255,255,${p.life/20})`;ctx.beginPath();ctx.arc(p.x,p.y,2,0,Math.PI*2);ctx.fill();});}function updateGame(){if(gameOver)return;npcs.forEach(npc=>{npc.update();if(npc.interactionTimer<=0){const nearbyAmenity=findNearestAmenity(npc.x,npc.y);if(nearbyAmenity&&Math.hypot(npc.x-nearbyAmenity.x,npc.y-nearbyAmenity.y)<20){satisfaction=Math.min(100,satisfaction+1);npc.interactionTimer=60;}}});satisfaction=Math.max(0,satisfaction-0.1);if(Math.random()<0.01&&grid.problemSpots.size<5){const x=Math.floor(Math.random()*GRID_SIZE);const y=Math.floor(Math.random()*GRID_SIZE);if(!grid.cells[x][y]){grid.problemSpots.add(`${x},${y}`);}}grid.problemSpots.forEach(spot=>{satisfaction=Math.max(0,satisfaction-0.05);});if(satisfaction<=0||budget<=0){endGame();}}function drawGame(){ctx.clearRect(0,0,canvas.width,canvas.height);drawGrid();placedAmenities.forEach(amenity=>{ctx.fillStyle=amenities[amenity.type].color;const size=amenities[amenity.type].size*CELL_SIZE;ctx.fillRect(amenity.x-size/2,amenity.y-size/2,size,size);});grid.problemSpots.forEach(spot=>{const[x,y]=spot.split(',').map(Number);ctx.fillStyle='rgba(255,0,0,0.5)';ctx.fillRect(x*CELL_SIZE,y*CELL_SIZE,CELL_SIZE,CELL_SIZE);});npcs.forEach(npc=>npc.draw());if(selectedAmenity){const mousePos=getMousePos(canvas,lastMouseEvent);const gridPos=getGridPos(mousePos.x,mousePos.y);if(isValidPlacement(gridPos.x,gridPos.y,amenities[selectedAmenity].size)){ctx.fillStyle=`${amenities[selectedAmenity].color}88`;const size=amenities[selectedAmenity].size*CELL_SIZE;ctx.fillRect(gridPos.x*CELL_SIZE,gridPos.y*CELL_SIZE,size,size);}}document.getElementById('budget').textContent=`Budget: ${budget}`;document.getElementById('satisfaction').textContent=`Satisfaction: ${Math.floor(satisfaction)}%`;document.getElementById('selectedItem').textContent=`Selected: ${selectedAmenity?amenities[selectedAmenity].name:'None'}`;}function drawGrid(){ctx.strokeStyle='#FFFFFF44';for(let i=0;i<=GRID_SIZE;i++){ctx.beginPath();ctx.moveTo(i*CELL_SIZE,0);ctx.lineTo(i*CELL_SIZE,canvas.height);ctx.stroke();ctx.beginPath();ctx.moveTo(0,i*CELL_SIZE);ctx.lineTo(canvas.width,i*CELL_SIZE);ctx.stroke();}}function getMousePos(canvas,evt){const rect=canvas.getBoundingClientRect();return{x:(evt.clientX-rect.left)/(rect.right-rect.left)*canvas.width,y:(evt.clientY-rect.top)/(rect.bottom-rect.top)*canvas.height};}function getGridPos(x,y){return{x:Math.floor(x/CELL_SIZE),y:Math.floor(y/CELL_SIZE)};}function isValidPlacement(gridX,gridY,size){if(gridX<0||gridY<0||gridX+size>GRID_SIZE||gridY+size>GRID_SIZE)return false;for(let i=0;i<size;i++){for(let j=0;j<size;j++){if(grid.cells[gridX+i][gridY+j])return false;}}return true;}function placeAmenity(gridX,gridY,amenityType){const amenity=amenities[amenityType];if(budget>=amenity.cost&&isValidPlacement(gridX,gridY,amenity.size)){budget-=amenity.cost;for(let i=0;i<amenity.size;i++){for(let j=0;j<amenity.size;j++){grid.cells[gridX+i][gridY+j]=amenityType;}}placedAmenities.push({type:amenityType,x:(gridX+amenity.size/2)*CELL_SIZE,y:(gridY+amenity.size/2)*CELL_SIZE});return true;}return false;}function endGame(){gameOver=true;const finalScore=Math.floor(satisfaction);if(finalScore>bestScore){bestScore=finalScore;document.getElementById('bestScore').textContent=`Best Score: ${bestScore}`;}document.getElementById('finalScore').textContent=finalScore;document.getElementById('gameOver').style.display='block';}let lastMouseEvent;canvas.addEventListener('mousemove',e=>{lastMouseEvent=e;});canvas.addEventListener('click',e=>{if(gameOver||!selectedAmenity)return;const mousePos=getMousePos(canvas,e);const gridPos=getGridPos(mousePos.x,mousePos.y);placeAmenity(gridPos.x,gridPos.y,selectedAmenity);});canvas.addEventListener('contextmenu',e=>{e.preventDefault();if(gameOver)return;const mousePos=getMousePos(canvas,e);const gridPos=getGridPos(mousePos.x,mousePos.y);const spotKey=`${gridPos.x},${gridPos.y}`;if(grid.problemSpots.has(spotKey)&&budget>=50){grid.problemSpots.delete(spotKey);budget-=50;}});document.addEventListener('keydown',e=>{const key=parseInt(e.key);if(key>=1&&key<=4){selectedAmenity=key;}});function gameLoop(){updateGame();drawGame();requestAnimationFrame(gameLoop);}gameLoop();</script></body></html>\", \"language\": \"html\"}]}",
