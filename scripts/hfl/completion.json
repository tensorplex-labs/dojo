      "completion": "{\"files\": [{\"filename\": \"index.html\", \"content\": \"<!DOCTYPE html>\\n<html lang=\\\"en\\\"><head><meta charset=\\\"utf-8\\\"/><meta content=\\\"width=device-width,initial-scale=1.0\\\" name=\\\"viewport\\\"/><title>Park Perfection</title><style>body,html{margin:0;padding:0;height:100%;overflow:hidden;font-family:Arial,sans-serif;background:#2a2a2a}#gameContainer{position:relative;width:100vmin;height:100vmin;margin:auto;background:#90EE90}#gameCanvas{position:absolute;top:0;left:0;width:100%;height:100%}#hud{position:absolute;top:10px;left:10px;right:10px;display:flex;justify-content:space-between;color:#fff;font-size:16px;text-shadow:1px 1px 2px rgba(0,0,0,0.5);background:rgba(0,0,0,0.3);padding:10px;border-radius:5px}#selectedItem{width:50px;height:50px;border:2px solid #fff;border-radius:5px;margin-right:10px}#weather{position:absolute;top:60px;left:10px;color:#fff;font-size:14px;text-shadow:1px 1px 2px rgba(0,0,0,0.5);background:rgba(0,0,0,0.3);padding:5px;border-radius:5px}#gameOver{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(0,0,0,0.8);color:#fff;padding:20px;border-radius:10px;text-align:center;display:none}#restartButton{margin-top:10px;padding:10px 20px;background:#4CAF50;border:none;color:#fff;border-radius:5px;cursor:pointer}#restartButton:hover{background:#45a049}.controls{position:absolute;bottom:10px;left:10px;color:#fff;font-size:14px;text-shadow:1px 1px 2px rgba(0,0,0,0.5);background:rgba(0,0,0,0.3);padding:5px;border-radius:5px}</style></head><body><div id=\\\"gameContainer\\\"><canvas id=\\\"gameCanvas\\\"></canvas><div id=\\\"hud\\\"><div style=\\\"display:flex;align-items:center\\\"><div id=\\\"selectedItem\\\"></div><div>Budget: <span id=\\\"budget\\\">1000</span></div></div><div>Satisfaction: <span id=\\\"satisfaction\\\">0</span>%</div><div>Best Score: <span id=\\\"bestScore\\\">0</span></div></div><div id=\\\"weather\\\">Weather: Sunny</div><div id=\\\"gameOver\\\"><h2>Game Over!</h2><p>Final Score: <span id=\\\"finalScore\\\">0</span></p><button id=\\\"restartButton\\\">Play Again</button></div><div class=\\\"controls\\\">1-4: Select Amenity | Click: Place | Right Click: Remove Problem</div></div><script src=\\\"index.js\\\"></script><script>const canvas=document.getElementById('gameCanvas');const ctx=canvas.getContext('2d');const GRID_SIZE=20;const CELL_SIZE=canvas.width/GRID_SIZE;let canvasSize=Math.min(window.innerWidth,window.innerHeight);function resizeCanvas(){canvasSize=Math.min(window.innerWidth,window.innerHeight);canvas.width=canvasSize;canvas.height=canvasSize;ctx.scale(canvasSize/800,canvasSize/800);}resizeCanvas();window.addEventListener('resize',resizeCanvas);const AMENITIES={1:{name:'Bench',cost:100,color:'#8B4513',size:1},2:{name:'Tree',cost:150,color:'#228B22',size:1},3:{name:'Playground',cost:300,color:'#FFD700',size:2},4:{name:'Fountain',cost:400,color:'#4169E1',size:2}};const WEATHER_TYPES=['Sunny','Rainy','Snowy'];let selectedAmenity=1;let budget=1000;let satisfaction=50;let bestScore=0;let gameOver=false;let weather='Sunny';let weatherTimer=60;const grid=Array(GRID_SIZE).fill().map(()=>Array(GRID_SIZE).fill(null));const npcs=[];const problemSpots=[];class NPC{constructor(){this.x=Math.random()*800;this.y=Math.random()*800;this.targetX=this.x;this.targetY=this.y;this.speed=weather==='Sunny'?3:2;}update(){const dx=this.targetX-this.x;const dy=this.targetY-this.y;const dist=Math.sqrt(dx*dx+dy*dy);if(dist<1){this.findNewTarget();}else{this.x+=dx/dist*this.speed;this.y+=dy/dist*this.speed;}}findNewTarget(){const nearbyAmenities=[];for(let i=0;i<GRID_SIZE;i++){for(let j=0;j<GRID_SIZE;j++){if(grid[i][j]){nearbyAmenities.push({x:j*40+20,y:i*40+20});}}}if(nearbyAmenities.length>0&&Math.random()<0.7){const target=nearbyAmenities[Math.floor(Math.random()*nearbyAmenities.length)];this.targetX=target.x;this.targetY=target.y;}else{this.targetX=Math.random()*800;this.targetY=Math.random()*800;}}draw(){ctx.fillStyle='#333';ctx.beginPath();ctx.arc(this.x,this.y,5,0,Math.PI*2);ctx.fill();}}function createSparkle(x,y){ctx.fillStyle='#FFD700';for(let i=0;i<10;i++){const angle=Math.random()*Math.PI*2;const distance=Math.random()*20;ctx.beginPath();ctx.arc(x+Math.cos(angle)*distance,y+Math.sin(angle)*distance,2,0,Math.PI*2);ctx.fill();}}function createSmoke(x,y){ctx.fillStyle='rgba(200,200,200,0.5)';for(let i=0;i<10;i++){const angle=Math.random()*Math.PI*2;const distance=Math.random()*15;ctx.beginPath();ctx.arc(x+Math.cos(angle)*distance,y+Math.sin(angle)*distance,5,0,Math.PI*2);ctx.fill();}}function drawGrid(){ctx.strokeStyle='#ffffff33';for(let i=0;i<=GRID_SIZE;i++){ctx.beginPath();ctx.moveTo(i*40,0);ctx.lineTo(i*40,800);ctx.stroke();ctx.beginPath();ctx.moveTo(0,i*40);ctx.lineTo(800,i*40);ctx.stroke();}}function drawAmenities(){for(let i=0;i<GRID_SIZE;i++){for(let j=0;j<GRID_SIZE;j++){if(grid[i][j]){const amenity=AMENITIES[grid[i][j]];ctx.fillStyle=amenity.color;ctx.fillRect(j*40,i*40,40*amenity.size,40*amenity.size);}}}problemSpots.forEach(spot=>{ctx.fillStyle='#FF0000';ctx.fillRect(spot.x*40,spot.y*40,40,40)});}function drawHover(mouseX,mouseY){if(!gameOver){const gridX=Math.floor(mouseX/40);const gridY=Math.floor(mouseY/40);const amenity=AMENITIES[selectedAmenity];if(canPlaceAmenity(gridX,gridY,amenity)){ctx.fillStyle=amenity.color+'80';ctx.fillRect(gridX*40,gridY*40,40*amenity.size,40*amenity.size);}}}function canPlaceAmenity(x,y,amenity){if(x<0||y<0||x+amenity.size>GRID_SIZE||y+amenity.size>GRID_SIZE)return false;if(weather==='Snowy'&&(amenity.name==='Fountain'||amenity.name==='Bench'))return false;for(let i=0;i<amenity.size;i++){for(let j=0;j<amenity.size;j++){if(grid[y+j][x+i])return false;}}return true;}function placeAmenity(x,y){const amenity=AMENITIES[selectedAmenity];if(canPlaceAmenity(x,y,amenity)&&budget>=amenity.cost){for(let i=0;i<amenity.size;i++){for(let j=0;j<amenity.size;j++){grid[y+j][x+i]=selectedAmenity;}}budget-=amenity.cost;createSparkle(x*40+20,y*40+20);updateBudget();}}function removeProblemSpot(x,y){const index=problemSpots.findIndex(spot=>spot.x===x&&spot.y===y);if(index!==-1){problemSpots.splice(index,1);budget-=50;createSmoke(x*40+20,y*40+20);updateBudget();}}function updateSatisfaction(){let newSatisfaction=50;npcs.forEach(npc=>{const gridX=Math.floor(npc.x/40);const gridY=Math.floor(npc.y/40);if(gridX>=0&&gridX<GRID_SIZE&&gridY>=0&&gridY<GRID_SIZE){if(grid[gridY][gridX]){const multiplier=weather==='Rainy'?0.5:weather==='Sunny'?1.5:1;newSatisfaction+=0.1*multiplier;}}});problemSpots.forEach(()=>{newSatisfaction-=0.2;});satisfaction=Math.max(0,Math.min(100,newSatisfaction));document.getElementById('satisfaction').textContent=Math.floor(satisfaction);if(satisfaction<=0||budget<0){endGame();}}function updateWeather(){weatherTimer--;if(weatherTimer<=0){weather=WEATHER_TYPES[Math.floor(Math.random()*WEATHER_TYPES.length)];weatherTimer=60;document.getElementById('weather').textContent='Weather: '+weather;npcs.forEach(npc=>{npc.speed=weather==='Sunny'?3:2;});}}function createProblemSpot(){if(Math.random()<0.02&&problemSpots.length<5){const x=Math.floor(Math.random()*GRID_SIZE);const y=Math.floor(Math.random()*GRID_SIZE);if(!grid[y][x]&&!problemSpots.some(spot=>spot.x===x&&spot.y===y)){problemSpots.push({x,y});}}}function updateBudget(){document.getElementById('budget').textContent=budget;}function endGame(){gameOver=true;const finalScore=Math.floor(satisfaction*budget/100);if(finalScore>bestScore){bestScore=finalScore;document.getElementById('bestScore').textContent=bestScore;}document.getElementById('finalScore').textContent=finalScore;document.getElementById('gameOver').style.display='block';}function startGame(){grid.forEach(row=>row.fill(null));npcs.length=0;problemSpots.length=0;for(let i=0;i<10;i++){npcs.push(new NPC());}budget=1000;satisfaction=50;gameOver=false;weather='Sunny';weatherTimer=60;document.getElementById('gameOver').style.display='none';updateBudget();}function gameLoop(){if(!gameOver){ctx.clearRect(0,0,800,800);drawGrid();drawAmenities();npcs.forEach(npc=>{npc.update();npc.draw();});const mouseX=lastMouseX/canvasSize*800;const mouseY=lastMouseY/canvasSize*800;drawHover(mouseX,mouseY);updateSatisfaction();updateWeather();createProblemSpot();}requestAnimationFrame(gameLoop);}let lastMouseX=0;let lastMouseY=0;canvas.addEventListener('mousemove',e=>{const rect=canvas.getBoundingClientRect();lastMouseX=e.clientX-rect.left;lastMouseY=e.clientY-rect.top;});canvas.addEventListener('click',e=>{if(!gameOver){const rect=canvas.getBoundingClientRect();const x=Math.floor((e.clientX-rect.left)/canvasSize*800/40);const y=Math.floor((e.clientY-rect.top)/canvasSize*800/40);placeAmenity(x,y);}});canvas.addEventListener('contextmenu',e=>{e.preventDefault();if(!gameOver){const rect=canvas.getBoundingClientRect();const x=Math.floor((e.clientX-rect.left)/canvasSize*800/40);const y=Math.floor((e.clientY-rect.top)/canvasSize*800/40);removeProblemSpot(x,y);}});window.addEventListener('keydown',e=>{const num=parseInt(e.key);if(num>=1&&num<=4){selectedAmenity=num;const selectedItemDiv=document.getElementById('selectedItem');selectedItemDiv.style.backgroundColor=AMENITIES[num].color;}});document.getElementById('restartButton').addEventListener('click',startGame);startGame();gameLoop();</script></body></html>\", \"language\": \"html\"}]}",
