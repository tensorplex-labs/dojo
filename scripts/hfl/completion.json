      "completion": "{\"files\": [{\"filename\": \"index.html\", \"content\": \"<!DOCTYPE html>\\n<html lang=\\\"en\\\"><head><meta charset=\\\"utf-8\\\"/><meta content=\\\"width=device-width, initial-scale=1.0\\\" name=\\\"viewport\\\"/><title>Zoo Zone</title><style>body{margin:0;display:flex;justify-content:center;align-items:center;min-height:100vh;background:#2F4F4F;font-family:Arial,sans-serif}#gameContainer{position:relative;background:#FFF8DC;padding:20px;border-radius:10px;box-shadow:0 0 20px rgba(0,0,0,0.3)}#gameCanvas{display:block;background:#DEB887;border:2px solid #8B4513}#controls{position:absolute;bottom:-40px;left:50%;transform:translateX(-50%);color:#fff;font-size:14px;text-align:center;white-space:nowrap}</style></head><body><div id=\\\"gameContainer\\\"><canvas id=\\\"gameCanvas\\\"></canvas><div id=\\\"controls\\\">1-4: Select Exhibit | Left Click: Place | Right Click: Fix Issues</div></div><script src=\\\"index.js\\\"></script><script>const canvas=document.getElementById(\\\"gameCanvas\\\"),ctx=canvas.getContext(\\\"2d\\\");let gridSize=20,cellSize=30,budget=1000,happiness=50,bestScore=0,selectedExhibit=1;const exhibits=[null,{name:\\\"Enclosure\\\",cost:100,color:\\\"#8B4513\\\"},{name:\\\"Feeding Station\\\",cost:150,color:\\\"#228B22\\\"},{name:\\\"Rest Area\\\",cost:80,color:\\\"#4682B4\\\"},{name:\\\"Water Feature\\\",cost:200,color:\\\"#40E0D0\\\"}];const grid=Array(gridSize).fill().map(()=>Array(gridSize).fill(null));const visitors=[];const maintenanceIssues=[];let gameOver=false;let score=0;function initGame(){for(let i=0;i<10;i++)visitors.push({x:Math.random()*canvas.width,y:Math.random()*canvas.height,dx:Math.random()*2-1,dy:Math.random()*2-1,happiness:0})}function drawGrid(){ctx.fillStyle=\\\"#DEB887\\\";ctx.fillRect(0,0,canvas.width,canvas.height);for(let i=0;i<gridSize;i++)for(let j=0;j<gridSize;j++){ctx.strokeStyle=\\\"rgba(0,0,0,0.1)\\\";ctx.strokeRect(i*cellSize,j*cellSize,cellSize,cellSize);if(grid[i][j]){ctx.fillStyle=exhibits[grid[i][j]].color;ctx.fillRect(i*cellSize,j*cellSize,cellSize,cellSize)}}maintenanceIssues.forEach(issue=>{ctx.fillStyle=\\\"rgba(255,0,0,0.5)\\\";ctx.fillRect(issue.x*cellSize,issue.y*cellSize,cellSize,cellSize)})}function drawVisitors(){ctx.fillStyle=\\\"#333\\\";visitors.forEach(visitor=>{ctx.beginPath();ctx.arc(visitor.x,visitor.y,5,0,Math.PI*2);ctx.fill()})}function drawUI(){ctx.fillStyle=\\\"#000\\\";ctx.font=\\\"20px Arial\\\";ctx.fillText(`Budget: $${budget}`,10,30);ctx.fillText(`Happiness: ${Math.floor(happiness)}%`,10,60);ctx.fillText(`Score: ${score}`,10,90);ctx.fillText(`Best Score: ${bestScore}`,10,120);if(selectedExhibit){ctx.fillStyle=exhibits[selectedExhibit].color;ctx.fillRect(canvas.width-100,10,40,40);ctx.fillStyle=\\\"#000\\\";ctx.fillText(exhibits[selectedExhibit].name,canvas.width-200,35)}}function updateVisitors(){visitors.forEach(visitor=>{let nearestExhibit=null,minDist=Infinity;for(let i=0;i<gridSize;i++)for(let j=0;j<gridSize;j++)if(grid[i][j]){const dx=i*cellSize+cellSize/2-visitor.x,dy=j*cellSize+cellSize/2-visitor.y,dist=Math.sqrt(dx*dx+dy*dy);if(dist<minDist){minDist=dist;nearestExhibit={x:i*cellSize+cellSize/2,y:j*cellSize+cellSize/2}}}if(nearestExhibit){const dx=nearestExhibit.x-visitor.x,dy=nearestExhibit.y-visitor.y,dist=Math.sqrt(dx*dx+dy*dy);if(dist<100){visitor.happiness+=0.1;happiness=Math.min(100,happiness+0.01)}visitor.dx+=dx/dist*0.1;visitor.dy+=dy/dist*0.1}visitor.dx*=0.95;visitor.dy*=0.95;visitor.x+=visitor.dx;visitor.y+=visitor.dy;visitor.x=Math.max(0,Math.min(canvas.width,visitor.x));visitor.y=Math.max(0,Math.min(canvas.height,visitor.y))})}function createMaintenanceIssue(){if(Math.random()<0.01&&maintenanceIssues.length<5){const x=Math.floor(Math.random()*gridSize),y=Math.floor(Math.random()*gridSize);if(grid[x][y]&&!maintenanceIssues.some(issue=>issue.x===x&&issue.y===y))maintenanceIssues.push({x,y})}}function updateGame(){if(!gameOver){updateVisitors();createMaintenanceIssue();happiness=Math.max(0,happiness-0.01);score=Math.floor(visitors.reduce((sum,v)=>sum+v.happiness,0)+budget/10);if(happiness<=0||budget<=0){gameOver=true;if(score>bestScore)bestScore=score}}}function drawGameOver(){if(gameOver){ctx.fillStyle=\\\"rgba(0,0,0,0.7)\\\";ctx.fillRect(0,0,canvas.width,canvas.height);ctx.fillStyle=\\\"#fff\\\";ctx.font=\\\"40px Arial\\\";ctx.fillText(\\\"Game Over!\\\",canvas.width/2-100,canvas.height/2-20);ctx.font=\\\"20px Arial\\\";ctx.fillText(`Final Score: ${score}`,canvas.width/2-70,canvas.height/2+20);ctx.fillText(\\\"Click to restart\\\",canvas.width/2-60,canvas.height/2+60)}}function gameLoop(){ctx.clearRect(0,0,canvas.width,canvas.height);drawGrid();drawVisitors();drawUI();drawGameOver();updateGame();requestAnimationFrame(gameLoop)}function handleClick(e){const rect=canvas.getBoundingClientRect(),x=Math.floor((e.clientX-rect.left)/cellSize),y=Math.floor((e.clientY-rect.top)/cellSize);if(gameOver){gameOver=false;grid.forEach(row=>row.fill(null));visitors.forEach(v=>{v.happiness=0;v.x=Math.random()*canvas.width;v.y=Math.random()*canvas.height});maintenanceIssues.length=0;budget=1000;happiness=50;score=0;return}if(e.button===2){const issueIndex=maintenanceIssues.findIndex(issue=>issue.x===x&&issue.y===y);if(issueIndex!==-1&&budget>=20){budget-=20;maintenanceIssues.splice(issueIndex,1);createSparkle(x*cellSize+cellSize/2,y*cellSize+cellSize/2)}}else if(selectedExhibit&&x>=0&&x<gridSize&&y>=0&&y<gridSize&&!grid[x][y]&&budget>=exhibits[selectedExhibit].cost){budget-=exhibits[selectedExhibit].cost;grid[x][y]=selectedExhibit;createSparkle(x*cellSize+cellSize/2,y*cellSize+cellSize/2)}}function createSparkle(x,y){ctx.fillStyle=\\\"#FFD700\\\";for(let i=0;i<10;i++){const angle=Math.random()*Math.PI*2,dist=Math.random()*20;ctx.beginPath();ctx.arc(x+Math.cos(angle)*dist,y+Math.sin(angle)*dist,2,0,Math.PI*2);ctx.fill()}}canvas.width=gridSize*cellSize;canvas.height=gridSize*cellSize;canvas.addEventListener(\\\"click\\\",handleClick);canvas.addEventListener(\\\"contextmenu\\\",e=>{e.preventDefault();handleClick(e)});document.addEventListener(\\\"keydown\\\",e=>{const num=parseInt(e.key);if(num>=1&&num<=4)selectedExhibit=num});initGame();gameLoop();</script></body></html>\", \"language\": \"html\"}]}",
