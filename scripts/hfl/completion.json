      "completion": "{\"files\": [{\"filename\": \"index.html\", \"content\": \"<!DOCTYPE html>\\n<html lang=\\\"en\\\"><head><meta charset=\\\"utf-8\\\"/><meta content=\\\"width=device-width,initial-scale=1.0\\\" name=\\\"viewport\\\"/><title>Park Perfection</title><style>body,html{margin:0;padding:0;height:100%;overflow:hidden;font-family:Arial,sans-serif;background:#333}#gameContainer{position:relative;width:100vmin;height:100vmin;margin:auto}#gameCanvas{position:absolute;top:0;left:0;width:100%;height:100%;cursor:pointer}#hud{position:absolute;top:10px;left:10px;right:10px;display:flex;justify-content:space-between;align-items:center;color:white;font-size:18px;text-shadow:2px 2px 4px rgba(0,0,0,0.5)}#selectedAmenity{padding:5px 10px;border-radius:5px;min-width:100px;text-align:center}#satisfactionContainer{width:200px;height:20px;background:rgba(255,255,255,0.2);border-radius:10px;overflow:hidden}#satisfactionFill{width:50%;height:100%;background:linear-gradient(90deg,#ff6b6b,#ff8787);transition:width 0.3s}#gameOver{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(0,0,0,0.8);color:white;padding:20px;border-radius:10px;text-align:center;display:none;flex-direction:column;align-items:center}#playAgain{margin-top:20px;padding:10px 20px;font-size:18px;background:#4CAF50;color:white;border:none;border-radius:5px;cursor:pointer}#playAgain:hover{background:#45a049}</style></head><body><div id=\\\"gameContainer\\\"><canvas id=\\\"gameCanvas\\\"></canvas><div id=\\\"hud\\\"><div id=\\\"selectedAmenity\\\">Bench</div><div id=\\\"budget\\\">1000</div><div id=\\\"satisfactionContainer\\\"><div id=\\\"satisfactionFill\\\"></div></div><div id=\\\"bestScore\\\">Best: 0</div></div><div id=\\\"gameOver\\\"><h2>Game Over!</h2><p>Final Score: <span id=\\\"finalScore\\\">0</span></p><button id=\\\"playAgain\\\">Play Again</button></div></div><script src=\\\"index.js\\\"></script><script>const canvas=document.getElementById('gameCanvas');const ctx=canvas.getContext('2d');const satisfactionMeter=document.getElementById('satisfactionFill');const budgetElement=document.getElementById('budget');const bestScoreElement=document.getElementById('bestScore');const gameOverScreen=document.getElementById('gameOver');const finalScoreElement=document.getElementById('finalScore');const selectedIndicator=document.getElementById('selectedAmenity');let canvasWidth=800;let canvasHeight=800;let scale=1;function resizeCanvas(){const container=document.getElementById('gameContainer');const containerWidth=container.clientWidth;const containerHeight=container.clientHeight;scale=Math.min(containerWidth/canvasWidth,containerHeight/canvasHeight);canvas.width=canvasWidth*scale;canvas.height=canvasHeight*scale;ctx.scale(scale,scale);}window.addEventListener('resize',resizeCanvas);resizeCanvas();const GRID_SIZE=20;const CELL_SIZE=canvasWidth/GRID_SIZE;const amenities={1:{name:'Bench',cost:100,color:'#8B4513',width:2,height:1},2:{name:'Tree',cost:150,color:'#228B22',width:1,height:1},3:{name:'Playground',cost:300,color:'#FFD700',width:2,height:2},4:{name:'Fountain',cost:400,color:'#4169E1',width:2,height:2}};let selectedAmenity=1;let budget=1000;let satisfaction=50;let bestScore=0;let gameOver=false;const placedAmenities=[];const npcs=[];const problemSpots=[];class NPC{constructor(){this.x=Math.random()*canvasWidth;this.y=Math.random()*canvasHeight;this.targetX=Math.random()*canvasWidth;this.targetY=Math.random()*canvasHeight;this.speed=1;this.happiness=0;}update(){const dx=this.targetX-this.x;const dy=this.targetY-this.y;const dist=Math.sqrt(dx*dx+dy*dy);if(dist<5){this.targetX=Math.random()*canvasWidth;this.targetY=Math.random()*canvasHeight;}else{this.x+=dx/dist*this.speed;this.y+=dy/dist*this.speed;}let nearAmenity=false;placedAmenities.forEach(amenity=>{const amenityCenter={x:amenity.x*CELL_SIZE+amenities[amenity.type].width*CELL_SIZE/2,y:amenity.y*CELL_SIZE+amenities[amenity.type].height*CELL_SIZE/2};const distToAmenity=Math.sqrt(Math.pow(this.x-amenityCenter.x,2)+Math.pow(this.y-amenityCenter.y,2));if(distToAmenity<100){nearAmenity=true;this.targetX=amenityCenter.x;this.targetY=amenityCenter.y;}});if(nearAmenity){this.happiness=Math.min(this.happiness+0.1,1);}else{this.happiness=Math.max(this.happiness-0.05,0);}}}function createSparkleEffect(x,y){const particles=[];for(let i=0;i<20;i++){particles.push({x:x*CELL_SIZE+Math.random()*CELL_SIZE,y:y*CELL_SIZE+Math.random()*CELL_SIZE,life:1,speed:Math.random()*2+1,angle:Math.random()*Math.PI*2});}function updateParticles(){ctx.save();particles.forEach((p,index)=>{p.x+=Math.cos(p.angle)*p.speed;p.y+=Math.sin(p.angle)*p.speed;p.life-=0.02;if(p.life<=0)particles.splice(index,1);ctx.fillStyle=`rgba(255,255,255,${p.life})`;ctx.beginPath();ctx.arc(p.x,p.y,2,0,Math.PI*2);ctx.fill();});ctx.restore();if(particles.length>0)requestAnimationFrame(updateParticles);}requestAnimationFrame(updateParticles);}function createProblemSpot(){if(problemSpots.length<5){const x=Math.floor(Math.random()*GRID_SIZE);const y=Math.floor(Math.random()*GRID_SIZE);if(!placedAmenities.some(a=>a.x===x&&a.y===y)){problemSpots.push({x,y,timer:300});}}}function drawGrid(){ctx.strokeStyle='rgba(255,255,255,0.2)';for(let i=0;i<=GRID_SIZE;i++){ctx.beginPath();ctx.moveTo(i*CELL_SIZE,0);ctx.lineTo(i*CELL_SIZE,canvasHeight);ctx.stroke();ctx.beginPath();ctx.moveTo(0,i*CELL_SIZE);ctx.lineTo(canvasWidth,i*CELL_SIZE);ctx.stroke();}}function drawAmenities(){placedAmenities.forEach(amenity=>{const type=amenities[amenity.type];ctx.fillStyle=type.color;ctx.fillRect(amenity.x*CELL_SIZE,amenity.y*CELL_SIZE,type.width*CELL_SIZE,type.height*CELL_SIZE);});}function drawNPCs(){ctx.fillStyle='#FFF';npcs.forEach(npc=>{ctx.beginPath();ctx.arc(npc.x,npc.y,5,0,Math.PI*2);ctx.fill();if(npc.happiness>0){ctx.fillStyle=`rgba(255,255,0,${npc.happiness})`;ctx.beginPath();ctx.arc(npc.x,npc.y,8,0,Math.PI*2);ctx.fill();}});}function drawProblemSpots(){ctx.fillStyle='rgba(255,0,0,0.5)';problemSpots.forEach(spot=>{ctx.fillRect(spot.x*CELL_SIZE,spot.y*CELL_SIZE,CELL_SIZE,CELL_SIZE);});}function drawHoverPreview(mouseX,mouseY){if(!gameOver){const gridX=Math.floor(mouseX/CELL_SIZE);const gridY=Math.floor(mouseY/CELL_SIZE);const type=amenities[selectedAmenity];if(canPlaceAmenity(gridX,gridY,type)){ctx.fillStyle=`${type.color}50`;ctx.fillRect(gridX*CELL_SIZE,gridY*CELL_SIZE,type.width*CELL_SIZE,type.height*CELL_SIZE);}}}function canPlaceAmenity(x,y,type){if(x<0||y<0||x+type.width>GRID_SIZE||y+type.height>GRID_SIZE)return false;return!placedAmenities.some(a=>{const aType=amenities[a.type];return!(x>=a.x+aType.width||x+type.width<=a.x||y>=a.y+aType.height||y+type.height<=a.y);});}function updateSatisfaction(){let totalHappiness=npcs.reduce((sum,npc)=>sum+npc.happiness,0)/npcs.length;satisfaction=Math.max(0,Math.min(100,satisfaction+totalHappiness*0.1-problemSpots.length*0.2));satisfactionMeter.style.width=`${satisfaction}%`;if(satisfaction<=0){endGame();}}function updateGame(){if(!gameOver){npcs.forEach(npc=>npc.update());problemSpots.forEach((spot,index)=>{spot.timer--;if(spot.timer<=0)problemSpots.splice(index,1);});if(Math.random()<0.01)createProblemSpot();updateSatisfaction();}}function drawGame(){ctx.fillStyle='#90EE90';ctx.fillRect(0,0,canvasWidth,canvasHeight);drawGrid();drawAmenities();drawProblemSpots();drawNPCs();const mousePos=getMousePos(canvas,lastMouseEvent);if(mousePos)drawHoverPreview(mousePos.x,mousePos.y);}function endGame(){gameOver=true;const finalScore=Math.floor(satisfaction*10+budget);if(finalScore>bestScore){bestScore=finalScore;bestScoreElement.textContent=`Best: ${bestScore}`;}finalScoreElement.textContent=finalScore;gameOverScreen.style.display='flex';}let lastMouseEvent;canvas.addEventListener('mousemove',e=>{lastMouseEvent=e;});function getMousePos(canvas,evt){if(!evt)return null;const rect=canvas.getBoundingClientRect();return{x:(evt.clientX-rect.left)/scale,y:(evt.clientY-rect.top)/scale};}canvas.addEventListener('click',e=>{if(!gameOver){const mousePos=getMousePos(canvas,e);const gridX=Math.floor(mousePos.x/CELL_SIZE);const gridY=Math.floor(mousePos.y/CELL_SIZE);const type=amenities[selectedAmenity];if(canPlaceAmenity(gridX,gridY,type)&&budget>=type.cost){placedAmenities.push({x:gridX,y:gridY,type:selectedAmenity});budget-=type.cost;budgetElement.textContent=budget;createSparkleEffect(gridX,gridY);if(budget<=0)endGame();}}});canvas.addEventListener('contextmenu',e=>{e.preventDefault();if(!gameOver){const mousePos=getMousePos(canvas,e);const gridX=Math.floor(mousePos.x/CELL_SIZE);const gridY=Math.floor(mousePos.y/CELL_SIZE);const spotIndex=problemSpots.findIndex(spot=>spot.x===gridX&&spot.y===gridY);if(spotIndex!==-1&&budget>=50){problemSpots.splice(spotIndex,1);budget-=50;budgetElement.textContent=budget;createSparkleEffect(gridX,gridY);}}});document.addEventListener('keydown',e=>{const num=parseInt(e.key);if(num>=1&&num<=4){selectedAmenity=num;selectedIndicator.style.backgroundColor=amenities[num].color;selectedIndicator.textContent=amenities[num].name;}});function startGame(){budget=1000;satisfaction=50;gameOver=false;placedAmenities.length=0;problemSpots.length=0;npcs.length=0;for(let i=0;i<10;i++)npcs.push(new NPC());budgetElement.textContent=budget;gameOverScreen.style.display='none';selectedAmenity=1;selectedIndicator.style.backgroundColor=amenities[1].color;selectedIndicator.textContent=amenities[1].name;}function gameLoop(){updateGame();drawGame();requestAnimationFrame(gameLoop);}document.getElementById('playAgain').addEventListener('click',startGame);startGame();gameLoop();</script></body></html>\", \"language\": \"html\"}]}",
